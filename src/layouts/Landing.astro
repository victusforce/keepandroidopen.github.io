---
/**
 * Shared landing page layout used by both / and /{locale}/.
 * All content rendering happens here. The page files just provide
 * the locale and optional head slot content (e.g. redirect script).
 */
import Base from './Base.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import QuoteTicker from '../components/QuoteTicker.astro';
import LanguagePicker from '../components/LanguagePicker.astro';
import ShareRow from '../components/ShareRow.astro';
import signatures from '../data/signatures.yaml';
import { logoPath } from '../lib/signatures';
import { getLandingStrings, getTranslationPercent } from '../i18n/locales';
import { languages } from '../i18n/config';
import '../styles/landing.css';
import techPressQuotes from '../data/quotes/tech-press.yaml';
import editorialQuotes from '../data/quotes/editorials.yaml';
import orgQuotes from '../data/quotes/organizations.yaml';
import creatorQuotes from '../data/quotes/creators.yaml';
import communityQuotes from '../data/quotes/community.yaml';
import changeOrgQuotes from '../data/quotes/changeorg.yaml';

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const t = getLandingStrings(locale);
const translatePct = getTranslationPercent(locale);
const translateUrl = `https://github.com/keepandroidopen/keepandroidopen.github.io/tree/main/src/i18n/locales/${locale}.yaml`;

// Fisher-Yates shuffle
function shuffle<T>(arr: T[]): T[] {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

const pressItems = shuffle(techPressQuotes);
const editorialItems = shuffle(editorialQuotes);
const orgItems = shuffle(orgQuotes);
const creatorItems = shuffle(creatorQuotes);
const communityItems = shuffle(communityQuotes);

let filteredPetitionQuotes = (changeOrgQuotes as any[]).filter(q => q.lang === locale && !q.flag);
if (filteredPetitionQuotes.length < 10 && locale !== 'en') {
  filteredPetitionQuotes = (changeOrgQuotes as any[]).filter(q => q.lang === 'en' && !q.flag);
}
const petitionItems = shuffle(filteredPetitionQuotes).slice(0, 100);

const shuffledSigs = shuffle(signatures as any[]);
const sigCountryCount = new Set(signatures.map((s: any) => s.region).filter(Boolean)).size;

// countdown
const deadline = new Date('2026-09-30T00:00:00Z');
const now = new Date();
const daysLeft = Math.max(0, Math.ceil((deadline.getTime() - now.getTime()) / (1000 * 60 * 60 * 24)));

const ctaPath = locale === 'en' ? '/cta/' : `/${locale}/cta/`;
const homePath = locale === 'en' ? '/' : `/${locale}/`;
---
<Base title={t.title} lang={locale} description={t.description}>
  {/* Head slot: pages can inject scripts (e.g. the redirect script) */}
  <slot name="head" />

  <nav class="topbar">
    <ThemeToggle />
    <LanguagePicker locale={locale} />
  </nav>

  <main>
    <!-- Hero -->
    <section id="top" class="hero">
      <p class="hero-lede">
        <Fragment set:html={t.hero_lede} />
      </p>
      <div class="countdown-strip">
        <span class="countdown-number">{daysLeft}</span>
        <span class="countdown-label" set:html={t.hero_countdown_label} />
      </div>
      <p class="hero-sub" set:html={t.hero_sub} />
      <p class="hero-sub hero-kicker" set:html={t.hero_kicker} />
      <a href="#what" class="scroll-cue" aria-label="Read more">&#8595;</a>

      <p class="share-heading" set:html={t.closing_share_heading} />
      <ShareRow t={t} locale={locale} />
    </section>

    <!-- What's happening -->
    <section id="what">
      <h2 set:html={t.what_heading} />
      <p set:html={t.what_intro} />
      <p set:html={t.what_registration} />
      <ul>
        <li class="li-list li-money" set:html={t.what_req_fee} />
        <li class="li-list li-terms" set:html={t.what_req_terms} />
        <li class="li-list li-id" set:html={t.what_req_id} />
        <li class="li-list li-signing" set:html={t.what_req_signing} />
        <li class="li-list li-appids" set:html={t.what_req_appids} />
      </ul>
      <p class="pull-quote" set:html={t.what_pullquote} />
    </section>

    <!-- Who gets hurt -->
    <section id="impact">
      <h2 set:html={t.impact_heading} />
      <div class="impact-cards">
        <div class="impact-card impact-consumer">
          <h3 set:html={t.impact_you_heading} />
          <p set:html={t.impact_you_p1} />
          <p set:html={t.impact_you_p2} />
        </div>
        <div class="impact-card impact-dev">
          <h3 set:html={t.impact_dev_heading} />
          <p set:html={t.impact_dev_p1} />
          <p set:html={t.impact_dev_p2} />
        </div>
        <div class="impact-card impact-gov">
          <h3 set:html={t.impact_gov_heading} />
          <p set:html={t.impact_gov_p1} />
          <p set:html={t.impact_gov_p2} />
        </div>
      </div>
    </section>

    <!-- The "solution" that isn't -->
    <section id="advanced-flow">
      <div class="callout-warning callout-trapdoor">
        <h3 set:html={t.flow_heading} />
        <p set:html={t.flow_intro} />
        <ol class="scare-steps">
          <li set:html={t.flow_step1} />
          <li set:html={t.flow_step2} />
          <li set:html={t.flow_step3} />
          <li set:html={t.flow_step4} />
          <li set:html={t.flow_step5} />
          <li class="step-highlight" set:html={t.flow_step6} />
          <li set:html={t.flow_step7} />
          <li set:html={t.flow_step8} />
          <li set:html={t.flow_step9} />
        </ol>
        <p set:html={t.flow_summary} />
        <p set:html={t.flow_detail} />
      </div>
    </section>

    <!-- Why you should care -->
    <section id="precedent" class="precedent-section">
      <h2 set:html={t.precedent_heading} />
      <p class="pull-quote" set:html={t.precedent_pullquote} />
      <p set:html={t.precedent_p1} />
      <p set:html={t.precedent_p2} />
      <p set:html={t.precedent_arstechnica} />
    </section>

    <!-- Objections addressed -->
    <section id="objections" class="objections-section">
      <h2 set:html={t.objections_heading} />
      <details><summary><h4 set:html={t.obj_security_q} /></summary><p set:html={t.obj_security_a} /></details>
      <details><summary><h4 set:html={t.obj_sideloading_q} /></summary><p set:html={t.obj_sideloading_a} /></details>
      <details><summary><h4 set:html={t.obj_hide_q} /></summary><p set:html={t.obj_hide_a} /></details>
      <details><summary><h4 set:html={t.obj_apple_q} /></summary><p set:html={t.obj_apple_a} /></details>
      <details><summary><h4 set:html={t.obj_cost_q} /></summary><p set:html={t.obj_cost_a} /></details>
    </section>

    <!-- What you can do -->
    <section id="act" class="action-section">
      <h2 id="help" set:html={t.act_heading} />
      <div class="action-block">
        <h3 id="everyone" set:html={t.act_everyone_heading} />
        <ul>
          <li set:html={t.act_fdroid} />
          <li set:html={t.act_regulators} />
          <li set:html={t.act_share} />
          <li set:html={t.act_astroturf} />
          <li set:html={t.act_petition} />
          <li set:html={t.act_letter} />
          <li set:html={t.act_survey} />
        </ul>
      </div>
      <div class="action-block action-dev-block">
        <h3 id="developers" set:html={t.act_dev_heading} />
        <p set:html={t.act_dev_intro} />
        <p class="callout-resist" set:html={t.act_dev_resist} />
        <ul>
          <li set:html={t.act_dev_talk} />
          <li set:html={t.act_dev_warn} />
          <li set:html={t.act_dev_banner} />
        </ul>
      </div>
      <div class="action-block">
        <h3 set:html={t.act_google_heading} />
        <p set:html={t.act_google_text} />
      </div>
    </section>

    <!-- Signatories -->
    <section id="signatories" class="signatories-landing">
      <div class="sig-rule"></div>
      <h2 set:html={t.signatories_heading} />
      <p class="sig-count"><Fragment set:html={t.signatories_count.replace('{count}', String(signatures.length)).replace('{countries}', String(sigCountryCount))} /> <a href="/open-letter"><Fragment set:html={t.signatories_open_letter_link} /></a></p>
      <QuoteTicker direction="right" variant="sigs" duration={160}>
        {shuffledSigs.map((sig: any) => (
          <a href={`https://${sig.url}`} target="_blank" class="ticker-card tc-sig">
            <img class="sig-card-logo" src={logoPath(sig.url)} alt="" loading="lazy" />
            <span class="sig-card-name">{sig.organization}</span>
            <span class="sig-card-url">{sig.url}</span>
          </a>
        ))}
      </QuoteTicker>
      <p style="text-align:center; margin-top: 1rem;">
        <a href="/open-letter" class="more-link"><Fragment set:html={t.signatories_more} /> &rarr;</a>
      </p>
    </section>

    <!-- Press and coverage -->
    <section id="voices" class="voices-section">
      <h2 set:html={t.voices_heading} />
      <h3 class="voices-category" set:html={t.voices_press} />
      <QuoteTicker direction="left" variant="press" duration={270}>
        {pressItems.map((item: any) => (
          <blockquote class="ticker-card" data-color={item.color || null}>
            <p>"{item.quote}"</p>
            <cite>{item.author && <>{item.author}, </>}<a href={item.url} target="_blank">{item.source}</a></cite>
          </blockquote>
        ))}
      </QuoteTicker>
      <h3 class="voices-category" set:html={t.voices_editorials} />
      <QuoteTicker direction="right" variant="featured" duration={135}>
        {editorialItems.map((item: any) => (
          <blockquote class="ticker-card tc-featured" data-color={item.color || null}>
            <p>"{item.quote}"</p>
            <cite>{item.author && <>{item.author}, </>}<a href={item.url} target="_blank">{item.source}</a></cite>
          </blockquote>
        ))}
      </QuoteTicker>
      <h3 class="voices-category" set:html={t.voices_orgs} />
      <QuoteTicker direction="left" variant="org" duration={120}>
        {orgItems.map((item: any) => (
          <blockquote class="ticker-card" data-color={item.color || null}>
            <p>"{item.quote}"</p>
            <cite><a href={item.url} target="_blank">{item.source}</a></cite>
          </blockquote>
        ))}
      </QuoteTicker>
      <h3 class="voices-category" set:html={t.voices_creators} />
      <QuoteTicker direction="right" variant="video" duration={210}>
        {creatorItems.map((item: any) => (
          <blockquote class="ticker-card tc-video" data-color={item.color || null}>
            <p>"{item.quote}"</p>
            <cite>{item.author} &ndash; <a href={item.url} target="_blank">{item.link_text || 'YouTube'}</a></cite>
          </blockquote>
        ))}
      </QuoteTicker>
      <h3 class="voices-category" set:html={t.voices_community} />
      <QuoteTicker direction="left" variant="community" duration={180}>
        {communityItems.map((item: any) => (
          <blockquote class="ticker-card tc-community" data-color={item.color || null}>
            <p>"{item.quote}"</p>
            <cite>{item.author}{item.author_note && <> ({item.author_note})</>}, <a href={item.url} target="_blank">{item.source}</a></cite>
          </blockquote>
        ))}
      </QuoteTicker>

      {petitionItems.length > 0 && (
        <>
          <h3 class="voices-category" set:html={t.voices_petition} />
          <QuoteTicker direction="right" variant="petition" duration={240}>
            {petitionItems.map((item: any) => (
              <blockquote class="ticker-card tc-petition">
                <p>"{item.content}"</p>
                <cite>{item.author}, <a href="https://www.change.org/p/stop-google-from-limiting-apk-file-usage/" target="_blank">change.org</a></cite>
              </blockquote>
            ))}
          </QuoteTicker>
        </>
      )}

      <p style="text-align:center; margin-top: 2rem;">
        <a href={ctaPath} class="more-link"><Fragment set:html={t.voices_more} /> &rarr;</a>
      </p>
    </section>

    <!-- CTA banner -->
    <section id="take-action" class="cta-banner">
      <a href={ctaPath} class="cta-banner-link">
        <span class="cta-banner-label" set:html={t.cta_action_label} />
        <span class="cta-banner-desc" set:html={t.cta_action_desc} />
        <span class="cta-banner-arrow">&rarr;</span>
      </a>
      <a href="/open-letter" class="cta-banner-link cta-banner-link-alt">
        <span class="cta-banner-label" set:html={t.cta_letter_label} />
        <span class="cta-banner-desc" set:html={t.cta_letter_desc} />
        <span class="cta-banner-arrow">&rarr;</span>
      </a>
    </section>

    <!-- Closing -->
    <section id="share" class="closing">
      <p class="closing-lede"><Fragment set:html={t.closing_line1} /><br><Fragment set:html={t.closing_line2} /></p>
      <p set:html={t.closing_detail} />
      <p class="closing-cta"><strong><Fragment set:html={t.closing_cta} /></strong></p>
      <ShareRow t={t} locale={locale} />
    </section>
  </main>

  <footer class="landing-footer">
    <div class="landing-footer-inner">
      <div class="footer-brand">
        <a href={homePath} class="outerlync">
          <img class="innerlync" alt="Altered Deal Logo" src="/img/altered-deal.png" style="width: 150px;">
        </a>
        <h2 class="footer-title" set:html={t.title} />
        <div class="footer-social">
          <a href="https://techhub.social/@keepandroidopen" aria-label="Mastodon" title="Mastodon" rel="me" target="_blank"><span class="social-icon icon-mastodon" style="width:24px;height:24px"></span></a>
          <a href="https://bsky.app/profile/keepandroidopen.bsky.social" aria-label="BlueSky" title="BlueSky" target="_blank"><span class="social-icon icon-bluesky" style="width:24px;height:24px"></span></a>
          <a href="https://x.com/AlteredDeal" aria-label="Twitter" title="Twitter" target="_blank"><span class="social-icon icon-x" style="width:24px;height:24px"></span></a>
          <a href="https://linkedin.com/company/keepandroidopen" aria-label="LinkedIn" title="LinkedIn" target="_blank"><span class="social-icon icon-linkedin" style="width:24px;height:24px"></span></a>
        </div>
      </div>
      <div class="footer-links-row">
        <div class="footer-col">
          <h4 set:html={t.footer_get_involved} />
          <ul>
            <li><a href={ctaPath}><Fragment set:html={t.footer_take_action} /></a></li>
            <li><a href="/open-letter"><Fragment set:html={t.footer_open_letter} /></a></li>
            <li><a href="/banner"><Fragment set:html={t.footer_add_banner} /></a></li>
            <li><a href="https://www.change.org/p/stop-google-from-limiting-apk-file-usage/" target="_blank"><Fragment set:html={t.footer_sign_petition} /></a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4 set:html={t.footer_contact} />
          <ul>
            <li><a href="mailto:info@keepandroidopen.org">info@keepandroidopen.org</a></li>
            <li><a href="mailto:tips@keepandroidopen.org">tips@keepandroidopen.org</a></li>
            <li><a href="https://github.com/keepandroidopen/keepandroidopen.github.io/issues" target="_blank"><Fragment set:html={t.footer_report_issues} /></a></li>
            <li><a href={translateUrl} target="_blank"><Fragment set:html={t.footer_help_translate} />{translatePct < 100 && ` (${translatePct}% ${(languages as any)[locale].label})`}</a></li>
          </ul>
        </div>
      </div>
      <div id="disclaimers" class="footer-legal">
        <p set:html={t.site_disclaimer} />
        <p set:html={t.site_privacy} />
        <p><Fragment set:html={t.site_copyright} /> <a href="https://creativecommons.org/publicdomain/zero/1.0/">CC0 1.0 Universal</a><img src="/img/cc.svg" alt="CC0" style="max-width: 1em; max-height: 1em; margin-left: .2em;"><img src="/img/zero.svg" alt="Zero" style="max-width: 1em; max-height: 1em; margin-left: .2em;"></p>
      </div>
    </div>
  </footer>
</Base>
